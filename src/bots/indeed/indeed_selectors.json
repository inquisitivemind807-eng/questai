        "location": "[data-testid='inlineHeader-companyLocation'], .jobsearch-JobInfoHeader-companyLocation",
        "salary": "[data-testid='jobsearch-JobInfoHeader-salary']",
        "salaryInfoAndJobType": "#salaryInfoAndJobType",
        "jobType": "[data-testid='jobsearch-JobInfoHeader-jobType'], span.css-1u1g3ig",
        "internalApplyButton": "button[data-testid='indeedApply'], #indeedApplyButton, button.sp-IndeedApplyButton, button:has-text('Apply with Indeed'), button[data-testid='indeedApplyButton-test'], button:has-text('Apply now')",
        "externalApplyButton": "button[contenthtml*='Apply on company site'], button:has-text('Apply on company site'), a:has-text('Apply on company site')",
